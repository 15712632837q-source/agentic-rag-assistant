# 复制为 .env 并填入真实值
ARK_API_KEY=your_volcengine_ark_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 豆包文本模型的 endpoint id 或模型名
LLM_MODEL=your_doubao_endpoint_or_model
# 本地中文 embedding（首次运行自动下载，约百MB，离线可跑）
EMBED_MODEL=BAAI/bge-small-zh-v1.5
# 要检索的知识库目录（默认指向作者的「第二大脑」，换成任意 markdown 目录即可复用）
CORPUS_DIR=D:\项目\第二大脑
